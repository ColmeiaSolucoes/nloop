{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NLoop Feature State",
  "description": "State file for tracking a feature through the NLoop pipeline",
  "type": "object",
  "required": ["ticket_id", "ticket_title", "feature_dir", "workflow", "current_node", "status", "started_at", "updated_at"],
  "properties": {
    "ticket_id": {
      "type": "string",
      "description": "YouTrack ticket ID (e.g., PROJ-123)"
    },
    "ticket_title": {
      "type": "string",
      "description": "Human-readable ticket title"
    },
    "ticket_url": {
      "type": ["string", "null"],
      "description": "URL to the YouTrack ticket"
    },
    "ticket_description": {
      "type": ["string", "null"],
      "description": "Full ticket description text"
    },
    "ticket_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags from YouTrack ticket (used for workflow selection and skip conditions)"
    },
    "ticket_type": {
      "type": ["string", "null"],
      "description": "Ticket type from YouTrack (e.g., Bug, Feature, Task)"
    },
    "ticket_priority": {
      "type": ["string", "null"],
      "description": "Ticket priority from YouTrack (e.g., Critical, Major, Normal)"
    },
    "feature_dir": {
      "type": "string",
      "description": "Relative path to the feature workspace directory"
    },
    "workflow": {
      "type": "string",
      "description": "Name of the workflow YAML to use"
    },
    "workflow_matched_rule": {
      "type": ["string", "null"],
      "description": "Name of the workflow_mapping rule that matched (or null for default)"
    },
    "current_node": {
      "type": "string",
      "description": "Current node in the workflow graph"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "escalated", "completed", "failed", "aborted"],
      "description": "Overall feature status"
    },
    "trigger": {
      "type": "string",
      "enum": ["manual", "poll_auto", "poll_approved", "exec"],
      "description": "How this feature was triggered"
    },
    "source_file": {
      "type": ["string", "null"],
      "description": "Path to the original .md file (for exec trigger)"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "skipped_nodes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of nodes that were skipped during execution"
    },
    "review_rounds": {
      "type": "object",
      "description": "Counter of review rounds per target artifact",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "tasks": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "completed": { "type": "integer", "minimum": 0 },
        "in_progress": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "title": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed"] },
              "group": { "type": "integer" },
              "worktree_branch": { "type": ["string", "null"] },
              "assigned_at": { "type": ["string", "null"] },
              "completed_at": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Runtime metrics collected during pipeline execution",
      "properties": {
        "phases": {
          "type": "object",
          "description": "Duration in seconds per phase",
          "additionalProperties": { "type": "number" }
        },
        "bugs_found": { "type": "integer", "minimum": 0 },
        "bugs_fixed": { "type": "integer", "minimum": 0 },
        "first_pass_code_review": { "type": ["boolean", "null"] },
        "perf_findings": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer", "minimum": 0 },
            "warning": { "type": "integer", "minimum": 0 },
            "info": { "type": "integer", "minimum": 0 }
          }
        },
        "models_used": {
          "type": "object",
          "description": "Count of agent calls per model",
          "additionalProperties": { "type": "integer" }
        }
      }
    },
    "docs": {
      "type": "object",
      "description": "Documentation artifacts status",
      "properties": {
        "changelog_updated": { "type": "boolean" },
        "files_updated": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "pr": {
      "type": "object",
      "properties": {
        "url": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "platform": { "type": ["string", "null"] },
        "status": { "type": ["string", "null"] }
      }
    },
    "escalation": {
      "type": "object",
      "properties": {
        "active": { "type": "boolean" },
        "reason": { "type": ["string", "null"] },
        "node": { "type": ["string", "null"] },
        "at": { "type": ["string", "null"] }
      }
    },
    "notifications_sent": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event": { "type": "string" },
          "platform": { "type": "string" },
          "at": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "node": { "type": "string" },
          "agent": { "type": "string" },
          "action": { "type": "string" },
          "status": { "type": "string" },
          "round": { "type": "integer" },
          "model": { "type": ["string", "null"] },
          "started_at": { "type": "string" },
          "completed_at": { "type": ["string", "null"] },
          "output_artifact": { "type": ["string", "null"] },
          "decision": { "type": ["string", "null"] },
          "comments": { "type": ["string", "null"] }
        }
      }
    }
  }
}
